<h1>Products</h1>

<hr>

<% if(products.length === 0){ %>

    <p>No products found.</p>

<% } else { %>

<table border="1" cellpadding="10">

    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>SKU</th>
        <th>Price</th>
        <th>Stock</th>
    </tr>

    <% products.forEach(product => { %>

        <tr>

            <td><%= product.id %></td>

            <td><%= product.name %></td>

            <td><%= product.sku %></td>

            <td><%= product.price %></td>

            <td><%= product.stock %></td>

        </tr>

    <% }) %>

</table>

<% } %>