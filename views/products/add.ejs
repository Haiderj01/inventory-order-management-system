<h2>Add Product</h2>

<form action="/products/add" method="POST">

    <div>
        <label>Name</label><br>
        <input
            type="text"
            name="name"
            required
        >
    </div>

    <br>

    <div>
        <label>SKU</label><br>
        <input
            type="text"
            name="sku"
            required
        >
    </div>

    <br>

    <div>
        <label>Price</label><br>
        <input
            type="number"
            step="0.01"
            name="price"
            required
        >
    </div>

    <br>

    <div>
        <label>Stock</label><br>
        <input
            type="number"
            name="stock"
            required
        >
    </div>

    <br>

    <button type="submit">
        Save Product
    </button>

</form>