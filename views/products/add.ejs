<h2>Add Product</h2>

<% if (errors.length > 0) { %>

    <div class="alert alert-danger">
        <ul>

            <% errors.forEach(error => { %>
                <li><%= error %></li>
            <% }) %>

        </ul>
    </div>

<% } %>

<form action="/products/add" method="POST">

    <div>
        <label>Name</label><br>

        <input
            type="text"
            name="name"
            value="<%= old.name || '' %>"
            required
        >
    </div>

    <br>

    <div>
        <label>SKU</label><br>

        <input
            type="text"
            name="sku"
            value="<%= old.sku || '' %>"
            required
        >
    </div>

    <br>

    <div>
        <label>Price</label><br>

        <input
            type="number"
            step="0.01"
            name="price"
            value="<%= old.price || '' %>"
            required
        >
    </div>

    <br>

    <div>
        <label>Stock</label><br>

        <input
            type="number"
            name="stock"
            value="<%= old.stock || '' %>"
            required
        >
    </div>

    <br>

    <button type="submit">
        Save Product
    </button>

</form>